# Backend / frontend ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Optional GitLab defaults. These can also be configured in the Settings UI.
GIT_URL=https://gitlab.example.com
GIT_TOKEN=replace-with-your-gitlab-token
PROJECT_ID=group/project

# Optional AI settings. Git-only workflows do not require an LLM key.
OPENAI_API_KEY=replace-with-your-openai-compatible-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_MODEL=gpt-4o-mini

# Optional tracing.
LANGFUSE_PUBLIC_KEY=replace-with-your-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Development only. Set true if you intentionally want to reset local DB state.
RESET_DB_ON_STARTUP=false
